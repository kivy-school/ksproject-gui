#: import FT kivy.uix.screenmanager.FadeTransition

<ScrollView>:
    bar_color: app.interactive

<MainScreen>:
    CStackLayout:
        size_hint: 1, 1
        spacing: dp(8)
        padding: [0, 0, 0, 0]

        CBoxLayout:
            id: main_layout
            orientation: "vertical"


<CScreenManager>:
    transition: FT(duration=0.15, clearcolor=app.background)

<LoadingLayout>:
    size_hint: 1, 1

    CLoadingIndicator:
        active: True

<ActiveButton>:
    radius: self.height/2

<BanLayout>:
    bg_color: app.background

    CBoxLayout:
        orientation: "vertical"
        adaptive: [False, True]
        size_hint_x: 1
        spacing: dp(32)

        CIcon:
            icon: "error--filled"
            font_size: sp(128)
            color: app.support_error
            pos_hint: {"center_x": 0.5}

        CLabel:
            text: f"An Unknown error occurred!\nPlease try after some time."
            style: "heading_03"
            halign: "center"

        CLink:
            pos_hint: {"center_x": 0.5}
            role: "Large"
            on_press:
                app.ban_state(False)

            CLinkText:
                text: "Refresh"

            CLinkIcon:
                icon: "restart"
