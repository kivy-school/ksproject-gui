#: import datamodel libs.datamodel.datamodel

<IPermissions>:

    CBoxLayout:
        size_hint: [1, 1]
        orientation: "vertical"
        padding: [dp(16), 0]
        spacing: dp(16)

        CButtonPrimary:
            text: "Add permission"
            icon: "add--large"
            on_press:
                root.launch_modal()

        ScrollView:
            always_overscroll: False

            CStackLayout:
                id: PermLayout
                spacing: dp(16)
                adaptive: [False, True]
                padding: [dp(2), 0, dp(2), dp(128)]

<IPermission>:
    canvas.after:
        Color:
            rgba: app.interactive
        Line:
            width: dp(2)
            cap: "square"
            points: [self.x, self.y + dp(2), self.x, self.top - dp(2)]
    padding: [dp(16), dp(4), dp(4), dp(4)]
    bg_color: app.layer_01
    adaptive: [True, True]
    spacing: dp(16)

    CLabelNeutral:
        text: root.name
        size_hint_y: 1

    UIShellButton:
        variant: "Ghost"
        icon: "close"