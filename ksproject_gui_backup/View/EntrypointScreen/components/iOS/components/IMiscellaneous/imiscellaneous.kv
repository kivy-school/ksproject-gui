#: import datamodel libs.datamodel.datamodel
#: import datetime datetime.datetime

<IMiscellaneous>:

    CStackLayout:
        size_hint: 1, 1
        padding: dp(16)

        CGridLayout:
            cols: 3
            spacing: dp(16)

            ScrollView:
                do_scroll_x: False

                IMiscellaneousLayout:

            CDivider:
                orientation: "vertical"

            ScrollView:
                do_scroll_x: False

                BoxLayout:
                    size_hint: 1, None
                    height: self.minimum_height
                    padding: dp(16)
                    spacing: dp(16)

                    IOSPane:

                    IPresplashPane:

<IOSPane>:

    canvas:
        Color:
            rgba: [0, 0, 0, 1]
        SmoothRoundedRectangle:
            size: dp(80), dp(24)
            pos: self.center_x - dp(32), self.top - dp(32)
            radius: [dp(12)]
        Color:
            rgba: app.gray_90
        SmoothEllipse:
            size: dp(12), dp(12)
            pos: self.center_x + dp(28), self.top - dp(26)

        Color:
            rgba: [0, 0, 0, 0.7]
        SmoothRoundedRectangle:
            size: dp(100), dp(4)
            pos: self.center_x - dp(50), self.y + dp(8)
            radius: [dp(2)]

    canvas.after:
        Color:
            rgba: [1, 1, 1, 1]
        SvgInstruction:
            svg_path: "assets/appbar.svg"
            size: [dp(64), dp(12)]
            pos: [self.right - dp(80), self.top - dp(26)]

    size_hint: None, None
    height: dp(560)
    width: dp(288)
    bg_source: "assets/ioswall2.jpg"
    bg_color: app.transparent
    radius: dp(32)

    CRelativeLayout:
        size_hint: 1, 1

        CLabel:
            text: root.time
            pos: root.x, root.top - dp(26) - self.height
            style: "label_01"
            typeface: "IBM Plex Mono"
            -color: [1, 1, 1, 1]

        CGridLayout:
            cols: 4
            rows: 1
            adaptive: [False, True]
            pos: root.x + dp(16), base_grid.top + dp(48)
            spacing: dp(16)

            RoundedBoxLayout:
                bg_source: datamodel.android_icon
                radius: dp(12)
                size_hint: None, None
                size: dp(44), dp(44)

        RoundedBoxLayout:
            id: base_grid
            spacing: dp(16)
            pos_hint: {"center_x": 0.5}
            y: dp(16)
            padding: dp(16)
            radius: dp(32)
            adaptive: [True, True]
            bg_color: app.background_hover

            CIconCircular:
                bg_color: app.transparent
                font_size: dp(42)
                canvas.after:
                    Color:
                        rgba: [1, 1, 1, 1]
                    SvgInstruction:
                        svg_path: "assets/icontacts.svg"
                        size: self.size
                        pos: self.pos

            CIconCircular:
                font_size: dp(42)
                canvas.after:
                    Color:
                        rgba: [1, 1, 1, 1]
                    SvgInstruction:
                        svg_path: "assets/imessages.svg"
                        size: self.size
                        pos: self.pos

            CIconCircular:
                font_size: dp(44)
                canvas.after:
                    Color:
                        rgba: [1, 1, 1, 1]
                    SvgInstruction:
                        svg_path: "assets/icamera.svg"
                        size: self.size
                        pos: self.pos

            CIconCircular:
                font_size: dp(44)
                canvas.after:
                    Color:
                        rgba: [1, 1, 1, 1]
                    SvgInstruction:
                        svg_path: "assets/iphotos.svg"
                        size: self.size
                        pos: self.pos

<IPresplashPane@PreviewPane>:
    canvas:
        Color:
            rgba: [0, 0, 0, 1]
        SmoothRoundedRectangle:
            size: dp(80), dp(24)
            pos: self.center_x - dp(32), self.top - dp(32)
            radius: [dp(12)]
        Color:
            rgba: app.gray_90
        SmoothEllipse:
            size: dp(12), dp(12)
            pos: self.center_x + dp(28), self.top - dp(26)
        Color:
            rgba: [0, 0, 0, 0.7]
        SmoothRoundedRectangle:
            size: dp(100), dp(4)
            pos: self.center_x - dp(50), self.y + dp(8)
            radius: [dp(2)]

    canvas.after:
        Color:
            rgba: [1, 1, 1, 1]
        SvgInstruction:
            svg_path: "assets/appbar.svg"
            size: [dp(64), dp(12)]
            pos: [self.right - dp(80), self.top - dp(26)]
    size_hint: None, None
    height: dp(560)
    width: dp(288)
    bg_color: datamodel.android_presplash_color
    radius: dp(32)

    AsyncImage:
        source: datamodel.android_presplash
        opacity: 1 if self.texture else 0


<IMiscellaneousLayout>:
    adaptive: [False, True]
    orientation: "vertical"
    spacing: dp(16)
    padding: [dp(8), dp(16), dp(16), dp(128)]

    RoundedBoxLayout:
        bg_color: app.layer_01
        adaptive: [False, True]
        spacing: dp(16)
        padding: dp(32)

        CBoxLayout:
            adaptive: [False, True]
            orientation: "vertical"

            CLabel:
                text: "iOS app icon"
                style: "heading_02"
                -color: app.text_primary
                padding: [0, dp(8)]

            FileUploader:
                id: icon_uploader
                data_source: datamodel.android_icon

        ImagePreview:
            id: image_preview
            source: icon_uploader.data_source
            on_source:
                datamodel.android_icon = self.source
            size_hint: None, None
            pos_hint: {"top": 1.0}
            size: [dp(128), dp(128)] if icon_uploader.data_source else [0, 0]

    RoundedBoxLayout:
        bg_color: app.layer_01
        adaptive: [False, True]
        spacing: dp(16)
        padding: dp(32)

        CBoxLayout:
            adaptive: [False, True]
            orientation: "vertical"
            spacing: dp(16)

            CLabel:
                text: "iOS presplash"
                style: "heading_02"
                -color: app.text_primary
                padding: [0, dp(8)]

            FileUploader:
                id: presplash_uploader
                data_source: datamodel.android_presplash

            CBoxLayout:
                adaptive: [False, True]
                spacing: dp(16)
                padding: [0, dp(32)]

                CTextInputLayout:
                    size_hint_x: None
                    width: dp(288)
                    CTextInput:
                        id: presplash_color_input
                        text: datamodel.android_presplash_color
                    CTextInputLabel:
                        text: "Presplash color"
                    CTextInputTrailingIconButton:
                        icon: "checkmark"
                        on_press:
                            datamodel.android_presplash_color = root.parse_hex_lenient(presplash_color_input.text)

                CButtonCircular:
                    bg_color: datamodel.android_presplash_color
                    radius: self.height/2
                    font_size: dp(48)

        ImagePreview:
            id: image_preview
            source: presplash_uploader.data_source
            on_source:
                datamodel.android_presplash = self.source
            size_hint: None, None
            pos_hint: {"top": 1.0}
            size: [dp(196), dp(196)] if icon_uploader.data_source else [0, 0]
