#: import datamodel libs.datamodel.datamodel

<IHome>:
    CStackLayout:
        size_hint: [1, 1]

        CBoxLayout:
            adaptive: [False, False]
            spacing: dp(16)

            ScrollView:
                always_overscroll: False

                CGridLayout:
                    responsive: True
                    padding: [dp(2), 0]
                    min_cols: 2
                    cols: 2
                    max_cols: 2
                    adaptive: [False, True]
                    spacing: dp(16)

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                text: datamodel.ios_bundle_id or ""
                                on_text: datamodel.ios_bundle_id = self.text
                            CTextInputLabel:
                                text: "Bundle id"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "e.g. com.kivyschool.yourapp"

            CDivider:
                orientation: "vertical"

            # ScrollView:
            #     always_overscroll: False

            #     IRightLayout:

<IRightLayout@CBoxLayout>:
    adaptive: [False, True]
    orientation: "vertical"
    padding: [dp(2), dp(16), dp(16), dp(128)]
    spacing: dp(16)
