<EntrypointScreenView>:
    UIShellLayout:
        padding: [0, dp(48), 0, 0]

        CBoxLayout:
            size_hint: 1, 1
            orientation: "horizontal"
            spacing: dp(16)

            CBoxLayout:
                padding: [dp(16), dp(32)]
                bg_color: app.layer_01
                adaptive: [True, False]

                UIShellPanelSelectionLayout:
                    id: selection_layout
                    orientation: "vertical"
                    adaptive: [True, True]
                    pos_hint: {"top": 1.0}
                    spacing: dp(32)

                    SelectionItem:
                        source: "assets/python64.png"
                        on_press:
                            manager_screens.current = "python"

                    SelectionItem:
                        source: "assets/android64.png"
                        on_press:
                            manager_screens.current = "android"

                    SelectionItem:
                        source: "assets/apple64.png"
                        default: True
                        on_press:
                            manager_screens.current = "ios"

            UI:
                id: manager_screens

                IOS:
                    name: "ios"
                Android:
                    name: "android"
                Python:
                    name: "python"


    UIShell:
        id: right_panel_shell

        UIShellRightPanel:
            panel_shell: right_panel_shell
            visibility: shell_notification_btn.focus

    UIShell:
        id: header_shell

        UIShellHeader:
            id: shell_header
            bg_color: app.layer_01

            UIShellHeaderName:
                markup: True
                text: "[font=ibmplexsans]KSProject[/font] Studio"
                font_size: plex_20

            CAnchorLayout:
                anchor_x: "right"

                CGridLayout:
                    adaptive: [True, True]
                    rows: 1

                    UIShellButton:
                        id: shell_search_btn
                        icon: "search"

                    UIShellButton:
                        id: shell_notification_btn
                        icon: "notification"

                    UIShellButton:
                        id: shell_switcher_btn
                        icon: "switcher"

                    UIShellButton:
                        id: shell_theme_btn
                        icon: "moon" if (app.theme in ["White", "Gray10"]) else "sun"
                        on_press:
                            app.theme = "Gray100" if (app.theme == "White") else "White"

<SelectionItem>:
    canvas.after:
        Color:
            rgba: app.interactive if self.selected else app.transparent
        Line:
            width: dp(1)
            cap: "square"
            points: [self.x, self.y, self.right, self.y]
    size_hint: None, None
    width: dp(48)
    height: dp(48)
    padding: [0, dp(8)]
    on_press:
        self.selected = True
    AsyncImage:
        source: root.source
        size_hint: None, None
        width: dp(48)
        height: dp(48)
        fit_mode: "contain"
