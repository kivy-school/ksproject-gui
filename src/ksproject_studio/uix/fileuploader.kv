<FileUploader>:
    orientation: "vertical"
    adaptive: [False, True]

    CGridLayout:
        cols: 1
        spacing: dp(8)
        adaptive: [False, True]

        CBoxLayout:
            orientation: "vertical"
            adaptive: [False, True]
            size_hint_x: 0.7
            spacing: dp(16)

            CBoxLayout:
                orientation: "vertical"
                adaptive: [False, True]
                spacing: dp(8)

                CLabelNeutral:
                    text: "Upload file"
                    style: "heading_compact_01"

                CLabelNeutral:
                    text: root.description
                    style: "body_compact_01"

            CButtonPrimary:
                text: "Add file"
                role: "Medium"
                icon: "add--large"
                on_release: root.file_select()

            CBoxLayout:
                id: data_uploaded_files
                orientation: "vertical"
                adaptive: [False, True]
                spacing: dp(8)
